# JSW Pipes & Tubes Inventory

# Vite dev server port (default: 3000)
VITE_PORT=3000

# Supabase — get these from: supabase.com > Your Project > Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Planner (the "AI Planner" tab) ───────────────────────────────────────
# The Anthropic key powers the planner. It is read ONLY by the server-side
# function api/ai-planner.js — set it in the Vercel project (Settings ▸
# Environment Variables), NOT here, and NEVER with a VITE_ prefix (a VITE_ var
# is bundled into the public browser build). For local end-to-end testing with
# `vercel dev`, put it in .env.local (gitignored), still WITHOUT VITE_:
#   ANTHROPIC_API_KEY=sk-ant-...
#
# Optional server-side knobs (set in Vercel / .env.local):
#   ALLOWED_ORIGINS=https://your-app.vercel.app   # comma-separated CORS allowlist (localhost + *.vercel.app already allowed)
#   AI_PLANNER_TOKEN=some-shared-secret           # if set, the function requires this bearer token
#
# Optional client-side knobs (these MAY be VITE_; they are not secrets):
#   VITE_AI_FN_URL=                               # override the default same-origin /api/ai-planner (e.g. a preview deploy)
#   VITE_AI_PLANNER_TOKEN=                        # must match AI_PLANNER_TOKEN above if you enabled that gate
