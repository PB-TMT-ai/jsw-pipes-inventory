<mxfile host="app.diagrams.net" type="device">
  <diagram id="process-flow-1" name="Process Flow">
    <mxGraphModel dx="900" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title + subtitle -->
        <mxCell id="title" value="JSW Pipes &amp;amp; Tubes — Process Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1;fontColor=#1f2d3d;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1620" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Steel mother coil → finished tubes dispatched to customers" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#5f6b7a;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1620" height="22" as="geometry" />
        </mxCell>

        <!-- Container behind the database tables -->
        <mxCell id="dbgroup" value="Supabase Postgres — data saved at each stage" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#9aa5b1;verticalAlign=top;align=center;fontColor=#5f6b7a;fontSize=12;fontStyle=2;spacingTop=6;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="298" width="1620" height="146" as="geometry" />
        </mxCell>

        <!-- Stage boxes -->
        <mxCell id="s1" value="&lt;b&gt;1. Coil Inward&lt;/b&gt;&lt;br&gt;&lt;br&gt;Receive and register a steel &lt;b&gt;mother coil&lt;/b&gt; (HR coil)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;2. Slitting&lt;/b&gt;&lt;br&gt;&lt;br&gt;Slit the mother coil into narrower &lt;b&gt;baby coils&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="110" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;3. Production&lt;/b&gt;&lt;br&gt;&lt;br&gt;Make finished &lt;b&gt;tubes&lt;/b&gt; (SKU + no. of pieces) from baby coils" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="110" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;4. Dispatch&lt;/b&gt;&lt;br&gt;&lt;br&gt;Send finished &lt;b&gt;tubes&lt;/b&gt; to customers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1420" y="110" width="240" height="110" as="geometry" />
        </mxCell>

        <!-- Database table cylinders -->
        <mxCell id="c1" value="coils" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="baby_coils" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="540" y="330" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="productions" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1000" y="330" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="dispatches" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1460" y="330" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Main flow arrows (with the connecting logic) -->
        <mxCell id="e12" value="slit into baby coils;&lt;br&gt;weight split proportionally by width" style="endArrow=classic;html=1;fontSize=11;rounded=0;strokeColor=#3a4a5a;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;fontColor=#25303b;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e23" value="consume baby coils oldest-first (FIFO);&lt;br&gt;match width ±5 mm AND thickness ±0.3 mm" style="endArrow=classic;html=1;fontSize=11;rounded=0;strokeColor=#3a4a5a;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;fontColor=#25303b;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e34" value="dispatch inherits coil trace (FIFO);&lt;br&gt;every tube traces to baby coil + mother coil" style="endArrow=classic;html=1;fontSize=11;rounded=0;strokeColor=#3a4a5a;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;fontColor=#25303b;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Write arrows (stage saves to its table) -->
        <mxCell id="w1" value="saves to" style="endArrow=open;html=1;fontSize=10;rounded=0;strokeColor=#8a94a0;strokeWidth=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#8a94a0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s1" target="c1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w2" value="saves to" style="endArrow=open;html=1;fontSize=10;rounded=0;strokeColor=#8a94a0;strokeWidth=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#8a94a0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s2" target="c2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w3" value="saves to" style="endArrow=open;html=1;fontSize=10;rounded=0;strokeColor=#8a94a0;strokeWidth=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#8a94a0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s3" target="c3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w4" value="saves to" style="endArrow=open;html=1;fontSize=10;rounded=0;strokeColor=#8a94a0;strokeWidth=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#8a94a0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s4" target="c4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legbox" value="Legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fbfbfb;strokeColor=#b0b8c1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#5f6b7a;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="640" height="150" as="geometry" />
        </mxCell>
        <mxCell id="leg-sw1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="62" y="518" width="36" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg-t1" value="Process stage — what happens in the app" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#3a4a5a;" vertex="1" parent="1">
          <mxGeometry x="110" y="518" width="540" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg-sw2" value="" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="64" y="552" width="32" height="28" as="geometry" />
        </mxCell>
        <mxCell id="leg-t2" value="Database table (Supabase) — where the data is saved" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#3a4a5a;" vertex="1" parent="1">
          <mxGeometry x="110" y="552" width="540" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg-t3" value="→  Arrow label — the rule / logic that links two stages" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#3a4a5a;" vertex="1" parent="1">
          <mxGeometry x="62" y="590" width="600" height="24" as="geometry" />
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="&lt;b&gt;Note&lt;/b&gt;&lt;br&gt;A tube's weight comes from the SKU's &lt;b&gt;weightPerTube&lt;/b&gt; (kg → tonnes).&lt;br&gt;No density constants are used anywhere." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;verticalAlign=top;spacing=10;size=18;" vertex="1" parent="1">
          <mxGeometry x="720" y="480" width="740" height="110" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
