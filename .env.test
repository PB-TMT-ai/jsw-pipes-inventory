# Dummy Supabase credentials for E2E (Playwright) runs ONLY — NOT real secrets.
# These let src/lib/supabase.js construct a client so the app renders; reads/writes
# fail against this fake host, so the E2E tests exercise the optimistic in-session
# UI state (no persistence). Loaded via `vite --mode test`.
VITE_SUPABASE_URL=https://example.supabase.co
VITE_SUPABASE_ANON_KEY=test-anon-key-not-real
